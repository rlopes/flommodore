.zig-cache/
zig-out/
zig-pkg/
/release/
/debug/
/build/
/build-*/
/docgen_tmp/

.DS_Store

# Generated test ROMs (rebuilt by `zig build genroms`); nop_loop.rom stays tracked.
tests/roms/test_*.rom
tests/roms/font.rom

# The built BIOS firmware (rebuilt by `zig build bios`) — a build product,
# reproducible bit-exactly from src/bios/ by the deterministic toolchain.
rom/flommodore.rom

# Built example programs (rebuilt by `zig build examples`).
examples/*.flapp
examples/*.flsym
